# Hugging Face Configuration
HF_TOKEN=hf_your_token_here
HF_REPO_ID=username/dataset-name
HF_REPO_TYPE=dataset

# Dataset Split / Path inside repo (e.g. data/train, data/test)
HF_DATA_PATH=data/train

# Local directory to import from / export to
LOCAL_DATA_DIR=./local_data

# Optional: revision/branch (defaults to main)
HF_REVISION=main
