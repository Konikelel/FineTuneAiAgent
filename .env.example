# ── VLM Model ─────────────────────────────────────────────────────────────
VLM_MODEL_ID=Qwen/Qwen3-VL-8B-Instruct
HF_TOKEN=hf_your_token_here
HF_CACHE_DIR=/path/to/cache   # optional, defaults to ~/.cache/huggingface
MAX_NEW_TOKENS=512

# ── GPU / device selection ─────────────────────────────────────────────────
# Leave unset → auto-detect (cuda:0 if available, else cpu)
# CUDA_DEVICE=cpu          # force CPU
# CUDA_DEVICE=cuda         # first GPU, uses device_map=auto (spreads across all GPUs)
# CUDA_DEVICE=cuda:0       # pin to GPU 0 only  (no device_map)
# CUDA_DEVICE=cuda:1       # pin to GPU 1 only  (no device_map)
# CUDA_DEVICE=cuda:0,1     # multi-GPU spanning GPU 0 and 1 via device_map=auto
CUDA_DEVICE=

# ── Input source ───────────────────────────────────────────────────────────
INPUT_ID_COL=id
INPUT_BYTES_COL=data


ROOT_DIR=./data
# INPUT_DIR=./data/raw       # optional override; defaults to ROOT_DIR/raw
#
# Auto-derived from ROOT_DIR (do not set manually):
#   data/raw/                        ← raw input images
#   data/stages/filter/output/       ← filter stage parquet shards
#   data/stages/label/output/        ← label stage parquet shards (final)
#   data/checkpoints/                ← checkpoint JSON files

# ── Batching / sharding ────────────────────────────────────────────────────
BATCH_SIZE=10
NUM_BATCHES=           # leave empty to process all images
IMAGES_PER_SHARD=100

# ── Parquet ────────────────────────────────────────────────────────────────
PARQUET_COMPRESSION=snappy   # snappy | zstd | gzip | none

# ── Retry ──────────────────────────────────────────────────────────────────
VLM_MAX_ATTEMPTS=3
VLM_BACKOFF_BASE=4.0
VLM_BACKOFF_MAX=60.0
